---
import { Image } from "astro:assets";
import venue1 from "../assets/images/Venue-1.png";
import venue2 from "../assets/images/Venue-2.jpg";
import venue3 from "../assets/images/Venue-3.webp";
---

<section
  class="bg-linear-to-br from-gray-50 via-white to-gray-100 py-10 md:py-20 -my-10 md:-my-20"
>
  <div class="container text-center mySpace-y">
    <div data-usal="fade-u duration-300">
      <h3>Venue</h3>
      <h4 class="font-bold leading-normal">
        The Oakspace, <br />Oakwood Premier Cozmo Jakarta
      </h4>
      <p class="w-full md:w-1/2 pb-4 mx-auto">
        Jl. DR. Ide Anak Agung Gde Agung No.1 1, Kuningan, Mega Kuningan,
        Setiabudi, Jakarta, 12950, Indonesia
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-4 md:gap-6">
      <div
        class="w-full lg:w-[30%] overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
        data-usal="fade-u duration-300"
      >
        <Image
          src={venue1}
          alt="HighHouse Venue View 1"
          width="935"
          height="510"
          layout="constrained"
          class="object-cover w-full h-full"
        />
      </div>
      <div
        class="w-full lg:w-[30%] overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
        data-usal="fade-u duration-300 delay-200"
      >
        <Image
          src={venue2}
          alt="HighHouse Venue View 2"
          width="600"
          height="400"
          layout="constrained"
          class="object-cover w-full h-full"
        />
      </div>
      <div
        class="w-full lg:w-[30%] overflow-hidden rounded-lg shadow-lg hover:shadow-2xl transition-transform duration-500 hover:scale-105 aspect-video"
        data-usal="fade-u duration-300 delay-400"
      >
        <Image
          src={venue3}
          alt="HighHouse Venue View 3"
          width="1920"
          height="824"
          layout="constrained"
          class="object-cover w-full h-full"
        />
      </div>
    </div>
  </div>
</section>
